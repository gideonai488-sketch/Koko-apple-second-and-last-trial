{
  "expo": {
    "name": "1st Koko Spot",
    "slug": "1st-koko-spot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "firstkokospot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5C35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.firstkokospot.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR codes for promo offers.",
        "NSLocationWhenInUseUsageDescription": "Used to suggest delivery addresses near you.",
        "NSPhotoLibraryUsageDescription": "Used to update your profile photo."
      }
    },
    "android": {
      "package": "com.firstkokospot.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FF5C35"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF5C35"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to suggest delivery addresses near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to update your profile photo.",
          "cameraPermission": "Used to scan QR codes for promo offers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
